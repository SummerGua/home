---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import ThemeScript from '../components/ThemeScript.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, headings = [] } = Astro.props;
const tocHeadings = headings.filter((heading) => heading.depth <= 3);
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<ThemeScript />
		<style>
			.article-shell {
				--article-width: min(100%, calc(var(--reading-width) + 84px));
				display: grid;
				gap: 0.85rem;
			}

			.article-hero,
			.article-body {
				padding: 1rem 1.1rem;
			}

			.article-hero {
				display: grid;
				gap: 0.65rem;
				width: var(--article-width);
				justify-self: center;
			}

			.back-link {
				display: inline-flex;
				align-items: center;
				gap: 0.4rem;
				align-self: flex-start;
				padding: 0.15rem 0.1rem;
				margin-bottom: 0.15rem;
				border: 0;
				background: transparent;
				color: var(--muted);
				font: inherit;
				font-size: 0.78rem;
				font-weight: 700;
				letter-spacing: 0.12em;
				text-transform: uppercase;
				cursor: pointer;
				transition: color 120ms ease, transform 120ms ease;
			}

			.back-link:hover {
				color: var(--ink);
				transform: translateX(-2px);
			}

			.back-link .back-arrow {
				display: inline-block;
				transition: transform 120ms ease;
			}

			.back-link:hover .back-arrow {
				transform: translateX(-2px);
			}

			.meta {
				display: flex;
				flex-wrap: wrap;
				align-items: center;
				gap: 0.45rem 0.75rem;
				font-size: 0.78rem;
				font-weight: 700;
				letter-spacing: 0.12em;
				text-transform: uppercase;
				color: var(--muted);
			}

			.article-description {
				max-width: 46rem;
				margin-bottom: 0;
				color: var(--muted);
				font-size: 0.98rem;
				line-height: 1.6;
			}

			.category {
				display: inline-flex;
				align-items: center;
				padding: 0.18rem 0.5rem;
				background: var(--accent-soft);
				color: var(--ink);
				border-radius: 2px;
			}

			.article-body {
				width: var(--article-width);
				justify-self: center;
			}

			.article-toc {
				display: none;
				position: fixed;
				left: max(1.25rem, calc((100vw - min(var(--content-width), calc(100% - 3rem))) / 2 - 15rem));
				top: 8.75rem;
				z-index: 2;
				width: 12.5rem;
				overflow: hidden;
				padding: 0;
				background: transparent;
				border: 0;
				box-shadow: none;
			}

			.article-toc nav {
				border-left: 2px solid color-mix(in srgb, var(--ink) 20%, transparent);
				padding-left: 0.9rem;
			}

			.article-toc nav ul {
				list-style: none;
				padding: 0;
				margin: 0;
				display: grid;
				gap: 0.55rem;
				min-width: 0;
			}

			.article-toc nav li {
				padding-left: 0;
				min-width: 0;
			}

			.article-toc nav li.depth-3 {
				padding-left: 0.9rem;
			}

			.article-toc a {
				display: block;
				width: 100%;
				color: var(--muted);
				text-decoration: none;
				font-size: 0.92rem;
				line-height: 1.4;
				overflow: hidden;
				text-overflow: ellipsis;
				white-space: nowrap;
			}

			.article-toc a:hover {
				color: var(--ink);
				text-decoration: underline;
				text-decoration-thickness: 2px;
			}

			.article-toc a.active {
				color: var(--ink);
				font-weight: 700;
			}

			.prose :global(h2),
			.prose :global(h3),
			.prose :global(h4) {
				margin-top: 1.8rem;
				scroll-margin-top: 1.5rem;
			}

			.prose :global(p),
			.prose :global(ul),
			.prose :global(ol) {
				margin-bottom: 1rem;
			}

			.prose :global(blockquote p) {
				margin-bottom: 0.7rem;
			}

			.prose :global(blockquote p:last-child) {
				margin-bottom: 0;
			}

			.prose :global(p) {
				max-width: 46rem;
			}

			.prose :global(ul),
			.prose :global(ol),
			.prose :global(pre),
			.prose :global(blockquote) {
				max-width: 46rem;
			}

			.prose :global(:not(pre) > code) {
				padding: 0.08rem 0.3rem;
				border: 1px solid color-mix(in srgb, var(--line) 18%, transparent);
				border-radius: 0.22rem;
				background: color-mix(in srgb, var(--panel) 84%, var(--accent-soft) 16%);
				color: color-mix(in srgb, var(--ink) 94%, var(--accent) 6%);
				font-size: 0.84em;
				line-height: 1.45;
				word-break: break-word;
			}

			.prose :global(pre.astro-code) {
				margin: 0;
				padding: 1rem;
				font-size: 0.82rem;
				line-height: 1.55;
			}

			.prose :global(.code-block) {
				position: relative;
				max-width: 46rem;
				margin: 1.4rem 0 1rem;
			}

			.prose :global(.code-block::before) {
				content: attr(data-language);
				position: absolute;
				top: 0.55rem;
				right: 0.75rem;
				padding: 0.06rem 0.34rem;
				border: 1px solid color-mix(in srgb, white 14%, transparent);
				border-radius: 0.22rem;
				background: color-mix(in srgb, black 16%, transparent);
				color: color-mix(in srgb, #fff8ec 88%, var(--accent-soft) 12%);
				font-size: 0.66rem;
				font-weight: 700;
				letter-spacing: 0.04em;
				line-height: 1.2;
				text-transform: uppercase;
				transition: opacity 140ms ease;
			}

			.prose :global(.code-block:hover::before) {
				opacity: 0;
			}

			.prose :global(.code-block[data-language=''])::before,
			.prose :global(.code-block:not([data-language]))::before {
				content: 'TEXT';
			}

			.prose :global(.code-copy) {
				position: absolute;
				top: 0.5rem;
				right: 0.55rem;
				display: inline-flex;
				align-items: center;
				justify-content: center;
				width: 2.1rem;
				height: 2.1rem;
				padding: 0;
				border: 1px solid color-mix(in srgb, white 18%, transparent);
				border-radius: 0.32rem;
				background: color-mix(in srgb, black 28%, transparent);
				color: color-mix(in srgb, #fff8ec 90%, var(--accent-soft) 10%);
				cursor: pointer;
				opacity: 0;
				transform: translateY(-1px);
				transition: opacity 140ms ease, background-color 140ms ease, color 140ms ease;
			}

			.prose :global(.code-block:hover .code-copy),
			.prose :global(.code-copy:focus-visible) {
				opacity: 1;
			}

			.prose :global(.code-copy:hover) {
				background: color-mix(in srgb, black 46%, transparent);
			}

			.prose :global(.code-copy svg) {
				width: 1.15rem;
				height: 1.15rem;
				display: block;
			}

			.prose :global(.code-copy.copied) {
				color: #7ee2a8;
			}

			.prose :global(.code-block > pre.astro-code) {
				margin: 0;
			}

			.prose :global(pre.astro-code code) {
				display: grid;
			}

			.prose :global(pre.astro-code .line) {
				min-height: 1.45rem;
			}

			.prose :global(a) {
				color: var(--ink);
				text-decoration: underline;
				text-decoration-color: var(--accent);
				text-decoration-thickness: 2px;
				text-underline-offset: 0.16em;
				background-image: linear-gradient(
					to top,
					color-mix(in srgb, var(--accent-soft) 55%, transparent),
					color-mix(in srgb, var(--accent-soft) 55%, transparent)
				);
				background-repeat: no-repeat;
				background-position: 0 100%;
				background-size: 100% 45%;
				transition:
					color 180ms ease,
					text-decoration-color 180ms ease,
					background-size 220ms ease;
			}

			.prose :global(a:hover),
			.prose :global(a:focus-visible),
			.prose :global(a.link-active) {
				color: var(--ink);
				text-decoration-color: var(--accent);
				background-size: 100% 100%;
			}

			.article-hero h1 {
				font-size: clamp(1.9rem, 4.2vw, 3rem);
				line-height: 1.08;
				letter-spacing: -0.035em;
				max-width: 46rem;
				margin-bottom: 0.15rem;
			}

			.last-updated-on {
				font-style: italic;
			}

			@media (min-width: 1100px) {
				.article-toc {
					display: block;
				}
			}

			@media (min-width: 760px) {
				.article-hero,
				.article-body {
					padding: 1.2rem 1.45rem;
				}
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article class="article-shell">
				<div class="article-hero pixel-panel">
					<button class="back-link" type="button" data-back-button>
						<span class="back-arrow" aria-hidden="true">←</span>
						<span>Back</span>
					</button>
					<h1>{title}</h1>
					<div class="meta">
						<div class="category">{Astro.props.category}</div>
						<div>
							<FormattedDate date={pubDate} />
						</div>
						{
							updatedDate && (
								<div class="last-updated-on">
									Updated <FormattedDate date={updatedDate} />
								</div>
							)
						}
					</div>
					<p class="article-description">{description}</p>
				</div>
				{
					tocHeadings.length > 0 && (
						<aside class="article-toc" aria-label="Table of contents">
							<nav>
								<ul>
									{tocHeadings.map((heading) => (
										<li class={`depth-${heading.depth}`}>
											<a href={`#${heading.slug}`} data-toc-link={heading.slug}>
												{heading.text}
											</a>
										</li>
									))}
								</ul>
							</nav>
						</aside>
					)
				}
				<div class="article-body pixel-panel prose">
					<slot />
				</div>
			</article>
		</main>
		<Footer />
		</body>
</html>

<script>
	const backButton = document.querySelector('[data-back-button]');
	const codeBlocks = Array.from(document.querySelectorAll('.prose pre.astro-code'));
	const headings = Array.from(document.querySelectorAll('.prose h2, .prose h3'));
	const tocLinks = Array.from(document.querySelectorAll('[data-toc-link]'));

	if (backButton) {
		backButton.addEventListener('click', () => {
			if (window.history.length > 1) {
				window.history.back();
				return;
			}

			window.location.href = '/blog';
		});
	}

	for (const pre of codeBlocks) {
		if (pre.parentElement?.classList.contains('code-block')) continue;

		const wrapper = document.createElement('div');
		wrapper.className = 'code-block';
		wrapper.dataset.language = pre.dataset.language || 'TEXT';
		pre.parentNode?.insertBefore(wrapper, pre);
		wrapper.appendChild(pre);
	}

	const copyIconSvg =
		'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="11" height="11" rx="2"></rect><path d="M5 15V6a2 2 0 0 1 2-2h9"></path></svg>';
	const checkIconSvg =
		'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="4 12 10 18 20 6"></polyline></svg>';

	for (const wrapper of document.querySelectorAll('.prose .code-block')) {
		if (wrapper.querySelector('.code-copy')) continue;
		const button = document.createElement('button');
		button.type = 'button';
		button.className = 'code-copy';
		button.setAttribute('aria-label', 'Copy code');
		button.innerHTML = copyIconSvg;
		wrapper.appendChild(button);

		button.addEventListener('click', async () => {
			const pre = wrapper.querySelector('pre.astro-code');
			const text = pre?.innerText ?? '';
			try {
				await navigator.clipboard.writeText(text);
			} catch {
				const range = document.createRange();
				if (pre) range.selectNodeContents(pre);
				const selection = window.getSelection();
				selection?.removeAllRanges();
				selection?.addRange(range);
				document.execCommand('copy');
				selection?.removeAllRanges();
			}
			button.classList.add('copied');
			button.innerHTML = checkIconSvg;
			window.setTimeout(() => {
				button.classList.remove('copied');
				button.innerHTML = copyIconSvg;
			}, 1500);
		});
	}

	for (const link of document.querySelectorAll('.prose a[href]')) {
		const href = link.getAttribute('href') || '';
		if (href.startsWith('#')) continue;
		link.setAttribute('target', '_blank');
		link.setAttribute('rel', 'noopener noreferrer');
	}

	for (const link of document.querySelectorAll('.prose a[href]')) {
		link.addEventListener('click', () => {
			link.classList.add('link-active');
			window.setTimeout(() => link.classList.remove('link-active'), 320);
		});
	}

	if (headings.length && tocLinks.length) {
		const tocMap = new Map(tocLinks.map((link) => [link.dataset.tocLink, link]));

		const setActiveLink = (id) => {
			for (const link of tocLinks) {
				link.classList.toggle('active', link.dataset.tocLink === id);
			}
		};

		const observer = new IntersectionObserver(
			(entries) => {
				const visible = entries
					.filter((entry) => entry.isIntersecting)
					.sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);

				if (visible[0]?.target?.id) {
					setActiveLink(visible[0].target.id);
				}
			},
			{
				rootMargin: '-18% 0px -65% 0px',
				threshold: [0, 1],
			},
		);

		for (const heading of headings) observer.observe(heading);
		if (headings[0]?.id) setActiveLink(headings[0].id);
	}
</script>
