---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<a class="brand" href="/">
			<span class="brand-mark" aria-hidden="true"></span>
			<span>{SITE_TITLE}</span>
		</a>
		<div class="internal-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/blog">Blog</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
		</div>
	</nav>
</header>
<style>
	header {
		position: sticky;
		top: 0;
		z-index: 10;
		padding: 1rem 1rem 0;
	}
	nav {
		display: flex;
		flex-direction: column;
		gap: 0.9rem;
		padding: 0.9rem 1rem;
		border: 2px solid var(--ink);
		background: rgba(245, 240, 226, 0.92);
		backdrop-filter: blur(10px);
		box-shadow: 6px 6px 0 var(--shadow);
	}
	.brand {
		display: inline-flex;
		align-items: center;
		gap: 0.7rem;
		padding: 0;
		font-size: 0.92rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		border: 0;
	}
	.brand-mark {
		width: 0.95rem;
		height: 0.95rem;
		background:
			linear-gradient(90deg, transparent 20%, var(--accent) 20% 80%, transparent 80%),
			linear-gradient(transparent 20%, var(--accent) 20% 80%, transparent 80%);
		image-rendering: pixelated;
		box-shadow: 2px 2px 0 var(--ink);
	}
	.internal-links {
		display: flex;
		flex-wrap: wrap;
		gap: 0.6rem;
	}
	.internal-links :global(a) {
		min-width: 4.5rem;
	}
	@media (min-width: 760px) {
		header {
			padding: 1.5rem 1.5rem 0;
		}
		nav {
			flex-direction: row;
			align-items: center;
			justify-content: space-between;
			padding: 1rem 1.2rem;
		}
	}
</style>
