---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<a class="brand" href="/">
			<span class="brand-mark" aria-hidden="true"></span>
			<span>{SITE_TITLE}</span>
		</a>
		<div class="nav-actions">
			<div class="internal-links">
				<HeaderLink href="/blog">Posts</HeaderLink>
				<HeaderLink href="/categories">Categories</HeaderLink>
				<HeaderLink href="/archive">Archive</HeaderLink>
				<HeaderLink href="/about">About</HeaderLink>
			</div>
			<button class="theme-toggle" type="button" aria-label="Toggle dark mode" data-theme-toggle>
				<span class="theme-icon sun" aria-hidden="true">☀</span>
				<span class="theme-icon moon" aria-hidden="true">☾</span>
			</button>
		</div>
	</nav>
</header>
<style>
	header {
		padding: 1rem 1rem 0;
	}
	nav {
		display: flex;
		flex-direction: column;
		gap: 0.9rem;
		padding: 0.9rem 1rem;
		border: 1.5px solid var(--line);
		background: var(--panel);
		box-shadow: 5px 5px 0 var(--shadow);
		border-radius: 2px;
	}
	.brand {
		display: inline-flex;
		align-items: center;
		gap: 0.7rem;
		padding: 0;
		font-size: 0.92rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		border: 0;
	}
	.brand-mark {
		width: 0.95rem;
		height: 0.95rem;
		background:
			linear-gradient(90deg, transparent 20%, var(--accent) 20% 80%, transparent 80%),
			linear-gradient(transparent 20%, var(--accent) 20% 80%, transparent 80%);
		image-rendering: pixelated;
		box-shadow: 2px 2px 0 var(--ink);
	}
	.internal-links {
		display: flex;
		flex-wrap: wrap;
		gap: 0.6rem;
	}
	.nav-actions {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.75rem;
	}
	.internal-links :global(a) {
		min-width: 4.5rem;
	}
	.theme-toggle {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2.5rem;
		height: 2.5rem;
		padding: 0;
		border: 1.5px solid var(--line);
		background: transparent;
		color: var(--ink);
		box-shadow: 2px 2px 0 transparent;
		border-radius: 2px;
		cursor: pointer;
		transition:
			transform 120ms ease,
			box-shadow 120ms ease,
			background-color 120ms ease;
	}
	.theme-toggle:hover {
		transform: translate(-1px, -1px);
		background: var(--accent-soft);
		box-shadow: 3px 3px 0 var(--shadow);
	}
	.theme-icon {
		font-size: 1rem;
		line-height: 1;
	}
	.moon {
		display: none;
	}
	:global(html[data-theme='dark']) .sun {
		display: none;
	}
	:global(html[data-theme='dark']) .moon {
		display: inline;
	}
	@media (min-width: 760px) {
		header {
			padding: 1.5rem 1.5rem 0;
		}
		nav {
			flex-direction: row;
			align-items: center;
			justify-content: space-between;
			padding: 1rem 1.2rem;
		}
	}
</style>
