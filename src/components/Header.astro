---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav data-site-nav>
		<div class="nav-top">
			<a class="brand" href="/">
				<img class="brand-mark" src="/images/avatar.jpeg" alt="" width="24" height="24" />
				<span>{SITE_TITLE}</span>
			</a>
			<button
				class="menu-toggle"
				type="button"
				aria-label="Open menu"
				aria-controls="site-menu"
				aria-expanded="false"
				data-nav-toggle
			>
				<span aria-hidden="true"></span>
				<span aria-hidden="true"></span>
				<span aria-hidden="true"></span>
			</button>
		</div>
                <div class="nav-actions" id="site-menu">
                        <div class="nav-actions-inner">
                                <div class="internal-links">
                                        <HeaderLink href="/posts">Posts</HeaderLink>
                                        <HeaderLink href="/tags">Tags</HeaderLink>
                                        <HeaderLink href="/archive">Archive</HeaderLink>
                                        <HeaderLink href="/about">About</HeaderLink>
                                </div>
                                <button class="theme-toggle" type="button" aria-label="Toggle dark mode" data-theme-toggle>
                                        <span class="theme-icon sun" aria-hidden="true">☀</span>
                                        <span class="theme-icon moon" aria-hidden="true">☾</span>
                                </button>
			</div>
		</div>
	</nav>
</header>
<style>
	header {
		width: min(var(--content-width), calc(100% - 2rem));
		margin: 0 auto;
		padding: 1rem 0 0;
	}
	nav {
		display: flex;
		flex-direction: column;
                gap: 0;
		padding: 0.9rem 1rem;
		border: 1.5px solid var(--line);
		background: var(--panel);
		box-shadow: 5px 5px 0 var(--shadow);
		border-radius: 2px;
	}
	.nav-top {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.75rem;
		min-width: 0;
	}
	.brand {
		display: inline-flex;
		align-items: center;
		gap: 0.7rem;
		padding: 0.2rem 0.35rem 0.2rem 0.2rem;
		font-size: 1.05rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		border: 0;
		border-radius: 2px;
		min-width: 0;
		text-decoration: none;
		transition:
			transform 120ms ease,
			background-color 120ms ease,
			color 120ms ease;
	}
	.brand:hover {
		transform: translate(-1px, -1px);
		background: color-mix(in srgb, var(--accent-soft) 34%, transparent);
		color: var(--ink);
	}
	.brand:hover .brand-mark {
		box-shadow: 3px 3px 0 var(--shadow);
	}
	.brand span:last-child {
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
	}
	.brand-mark {
		flex: 0 0 auto;
		width: 1.5rem;
		height: 1.5rem;
		object-fit: cover;
		border: 1px solid var(--line);
		border-radius: 50%;
		background: var(--panel);
		image-rendering: pixelated;
		box-shadow: 2px 2px 0 var(--shadow);
		transition: box-shadow 120ms ease;
	}
	.internal-links {
		display: flex;
		flex-wrap: wrap;
		gap: 0.6rem;
	}
	.nav-actions {
                display: grid;
                grid-template-rows: 0fr;
                margin-top: 0;
                opacity: 0;
                transform: translateY(-0.35rem);
                transition:
                        grid-template-rows 180ms ease,
                        margin-top 180ms ease,
                        opacity 160ms ease,
                        transform 180ms ease;
	}
        .nav-actions-inner {
                display: flex;
                flex-wrap: wrap;
                align-items: center;
                gap: 0.75rem;
                min-height: 0;
                overflow: hidden;
        }
	.internal-links :global(a) {
		min-width: 4.5rem;
		text-align: center;
	}
	.theme-toggle {
		display: inline-flex;
		flex: 0 0 auto;
		align-items: center;
		justify-content: center;
		width: 2.1rem;
		height: 2.1rem;
		padding: 0;
		border: 1.5px solid var(--line);
		background: transparent;
		color: var(--ink);
		box-shadow: 2px 2px 0 transparent;
		border-radius: 2px;
		cursor: pointer;
		transition:
			transform 120ms ease,
			box-shadow 120ms ease,
			background-color 120ms ease;
	}
	.theme-toggle:hover {
		transform: translate(-1px, -1px);
		background: var(--accent-soft);
		box-shadow: 3px 3px 0 var(--shadow);
	}
	.menu-toggle {
		display: inline-flex;
		flex: 0 0 auto;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 4px;
		width: 2.5rem;
		height: 2.5rem;
		padding: 0;
		border: 1.5px solid var(--line);
                background: color-mix(in srgb, var(--panel) 86%, transparent);
		color: var(--ink);
                box-shadow: 2px 2px 0 color-mix(in srgb, var(--shadow) 72%, transparent);
		border-radius: 2px;
		cursor: pointer;
		transition:
			transform 120ms ease,
			box-shadow 120ms ease,
			background-color 120ms ease;
	}
	.menu-toggle:hover {
		transform: translate(-1px, -1px);
                background: color-mix(in srgb, var(--accent-soft) 32%, var(--panel));
		box-shadow: 3px 3px 0 var(--shadow);
	}
        nav[data-open='true'] .menu-toggle {
                background: color-mix(in srgb, var(--accent-soft) 45%, var(--panel));
                box-shadow: 3px 3px 0 var(--shadow);
        }
	.menu-toggle span {
		width: 1rem;
		height: 2px;
		background: currentColor;
		border-radius: 999px;
		transition:
			opacity 120ms ease,
			transform 120ms ease;
	}
	nav[data-open='true'] .menu-toggle span:nth-child(1) {
		transform: translateY(6px) rotate(45deg);
	}
	nav[data-open='true'] .menu-toggle span:nth-child(2) {
		opacity: 0;
	}
	nav[data-open='true'] .menu-toggle span:nth-child(3) {
		transform: translateY(-6px) rotate(-45deg);
	}
	.theme-icon {
		font-size: 1rem;
		line-height: 1;
	}
	.moon {
		display: none;
	}
	:global(html[data-theme='dark']) .sun {
		display: none;
	}
	:global(html[data-theme='dark']) .moon {
		display: inline;
	}
	@media (max-width: 759px) {
		nav[data-open='true'] .nav-actions {
                        grid-template-rows: 1fr;
                        margin-top: 0.75rem;
                        opacity: 1;
                        transform: translateY(0);
		}
                .nav-actions-inner {
                        display: grid;
                        grid-template-columns: 1fr auto;
                        align-items: start;
                        gap: 0.7rem;
                }
		.internal-links {
			display: grid;
			grid-template-columns: repeat(2, minmax(0, 1fr));
			gap: 0.55rem;
			padding-top: 0.15rem;
		}
		.internal-links :global(a) {
			min-width: 0;
			width: 100%;
			padding: 0.62rem 0.7rem;
			text-align: center;
		}
		.theme-toggle {
			width: 2.1rem;
			height: 2.1rem;
		}
		.menu-toggle {
			width: 2.35rem;
			height: 2.35rem;
		}
	}
	@media (min-width: 760px) {
		header {
			width: min(var(--content-width), calc(100% - 3rem));
			padding-top: 1.5rem;
		}
		nav {
			flex-direction: row;
			align-items: center;
			justify-content: space-between;
                        gap: 0.9rem;
			padding: 1rem 1.2rem;
		}
		.nav-top {
			display: block;
		}
		.nav-actions {
                        display: block;
                        margin-top: 0;
                        opacity: 1;
                        transform: none;
		}
                .nav-actions-inner {
                        overflow: visible;
                }
		.menu-toggle {
			display: none;
		}
	}
	@media (max-width: 520px) {
		header {
			width: calc(100% - 1rem);
                        padding-top: 0.5rem;
                }
                nav {
                        padding: 0.7rem 0.8rem;
		}
	}
</style>
<script>
	const nav = document.querySelector('[data-site-nav]');
	const toggle = document.querySelector('[data-nav-toggle]');
        const menu = document.querySelector('.nav-actions');

        const syncMenuA11y = () => {
                const isDesktop = window.matchMedia('(min-width: 760px)').matches;
                const isOpen = nav?.dataset.open === 'true';

                // 动画需要保留 DOM 可见性，移动端关闭时用 inert 避免隐藏链接被键盘聚焦。
                if (isDesktop || isOpen) {
                        menu?.removeAttribute('aria-hidden');
                        menu?.removeAttribute('inert');
                } else {
                        menu?.setAttribute('aria-hidden', 'true');
                        menu?.setAttribute('inert', '');
                }
        };

	const closeMenu = () => {
		nav?.removeAttribute('data-open');
		toggle?.setAttribute('aria-expanded', 'false');
		toggle?.setAttribute('aria-label', 'Open menu');
                syncMenuA11y();
	};

	toggle?.addEventListener('click', () => {
		const open = nav?.dataset.open === 'true';
		if (open) {
			closeMenu();
		} else {
			nav?.setAttribute('data-open', 'true');
			toggle.setAttribute('aria-expanded', 'true');
			toggle.setAttribute('aria-label', 'Close menu');
                        syncMenuA11y();
		}
	});

	nav?.addEventListener('click', (event) => {
		if (event.target instanceof HTMLAnchorElement) {
			closeMenu();
		}
	});

		// Prevent full-page reload when clicking the nav link for the current page
		for (const link of document.querySelectorAll('[aria-current="page"]')) {
			link.addEventListener('click', (e) => e.preventDefault());
		}

	window.addEventListener('resize', () => {
		if (window.matchMedia('(min-width: 760px)').matches) closeMenu();
                syncMenuA11y();
	});

        syncMenuA11y();
</script>
