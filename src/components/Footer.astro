---
const today = new Date();
---

<footer>
	<p class="footer-title">Pixel Notes</p>
	<p class="footer-copy">
		&copy; {today.getFullYear()} Personal writing, experiments, and build logs.
	</p>
	<p class="footer-meta">Markdown-first. Astro-powered. Mobile-friendly by default.</p>
</footer>
<style>
	footer {
		padding: 1.5rem 1rem 3rem;
		text-align: center;
		color: var(--muted);
	}
	p {
		margin: 0;
	}
	.footer-title {
		font-size: 0.82rem;
		font-weight: 700;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--ink);
	}
	.footer-copy,
	.footer-meta {
		margin-top: 0.5rem;
		font-size: 0.9rem;
	}
</style>
