---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import ThemeScript from '../components/ThemeScript.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const categories = Array.from(new Set(posts.flatMap((post) => post.data.tags))).sort((a, b) =>
	a.localeCompare(b),
);
const categoryCounts = categories.map((tag) => ({
	tag,
	count: posts.filter((post) => post.data.tags.includes(tag)).length,
}));
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Tags | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<ThemeScript />
	</head>
	<body>
		<Header />
		<main>
			<div class="page-shell">
				<section class="filters pixel-panel">
					<div class="filter-row" role="tablist" aria-label="Filter posts by tag">
						<button class="filter-chip active" type="button" data-filter="all" aria-pressed="true">
							All ({posts.length})
						</button>
						{
							categoryCounts.map(({ tag, count }) => (
								<button
									class="filter-chip"
									type="button"
									data-filter={tag}
									aria-pressed="false"
								>
									{tag} ({count})
								</button>
							))
						}
					</div>
				</section>

				<section class="post-grid" id="tag-post-grid">
					{
						posts.map((post) => (
							<article class="post-item pixel-panel" data-post-card data-tags={post.data.tags.join('|')}>
								<a class="post-link" href={`/posts/${post.id}/`}>
									<p class="date">
										<FormattedDate date={post.data.pubDate} />
									</p>
									<h2 class="title">{post.data.title}</h2>
									<p class="description">{post.data.description}</p>
									<div class="card-footer">
										<ul class="category-list">
											{post.data.tags.map((tag) => (
												<li class="category">{tag}</li>
											))}
										</ul>
									</div>
								</a>
							</article>
						))
					}
				</section>

				<p id="filter-empty" class="filter-empty pixel-panel" hidden>No posts with this tag yet.</p>
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	.filters,
	.filter-empty,
	.post-item {
		padding: 1.2rem;
	}

	.filter-row {
		display: flex;
		flex-wrap: wrap;
		gap: 0.65rem;
	}

	.filter-chip {
		padding: 0.45rem 0.75rem;
		border: 1.5px solid var(--line-soft);
		background: transparent;
		color: var(--muted);
		font: inherit;
		font-size: 0.8rem;
		font-weight: 700;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		border-radius: 2px;
		cursor: pointer;
		transition:
			background-color 120ms ease,
			color 120ms ease,
			border-color 120ms ease;
	}

	.filter-chip:hover {
		color: var(--ink);
		border-color: var(--line);
		background: color-mix(in srgb, var(--accent-soft) 45%, transparent);
	}

	.filter-chip.active {
		color: var(--ink);
		background: var(--accent-soft);
		border-color: var(--line);
	}

	.post-grid {
		display: grid;
		gap: 1rem;
	}

	.post-item {
		display: flex;
	}

	.post-item[hidden] {
		display: none;
	}

	.post-link {
		display: flex;
		flex-direction: column;
		width: 100%;
		text-decoration: none;
	}

	.category-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
	}

	.category {
		display: inline-flex;
		align-items: center;
		padding: 0.18rem 0.5rem;
		background: var(--accent-soft);
		color: var(--ink);
		font-size: 0.72rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		border-radius: 2px;
	}

	.date {
		margin: 0 0 0.55rem;
		font-size: 0.78rem;
		font-weight: 700;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--muted);
	}

	.title {
		margin: 0 0 0.55rem;
		font-size: 1.25rem;
		line-height: 1.3;
	}

	.description {
		margin: 0 0 1rem;
		color: var(--muted);
	}

	.card-footer {
		margin-top: auto;
		padding-top: 0.6rem;
		border-top: 1px solid color-mix(in srgb, var(--line) 12%, transparent);
		display: flex;
		align-items: center;
	}

	.post-item {
		transition:
			transform 120ms ease,
			box-shadow 120ms ease;
	}

	.post-item:hover {
		transform: translate(-1px, -1px);
		box-shadow: 6px 6px 0 var(--shadow);
	}

	.filter-empty {
		margin: 0;
	}

	@media (min-width: 760px) {
		.filters,
		.filter-empty,
		.post-item {
			padding: 1.4rem;
		}

		.post-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}
</style>

<script>
	const filterButtons = Array.from(document.querySelectorAll('[data-filter]'));
	const cards = Array.from(document.querySelectorAll('[data-post-card]'));
	const emptyState = document.querySelector('#filter-empty');

	const applyFilter = (selectedTag) => {
		let count = 0;

		for (const button of filterButtons) {
			const active = button.dataset.filter === selectedTag;
			button.classList.toggle('active', active);
			button.setAttribute('aria-pressed', String(active));
		}

		for (const card of cards) {
			const cardTags = (card.dataset.tags || '').split('|').filter(Boolean);
			const matched =
				selectedTag === 'all' || cardTags.includes(selectedTag);
			card.hidden = !matched;
			if (matched) count += 1;
		}

		if (emptyState) emptyState.hidden = count !== 0;
	};

	for (const button of filterButtons) {
		button.addEventListener('click', () => {
			applyFilter(button.dataset.filter || 'all');
		});
	}
</script>
