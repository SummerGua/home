---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import ThemeScript from '../components/ThemeScript.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const tagMap = new Map<string, typeof posts>();
for (const post of posts) {
	for (const tag of post.data.tags) {
		const list = tagMap.get(tag) ?? [];
		list.push(post);
		tagMap.set(tag, list);
	}
}

const tags = Array.from(tagMap.entries())
	.map(([tag, tagPosts]) => ({ tag, posts: tagPosts, count: tagPosts.length }))
	.sort((a, b) => b.count - a.count || a.tag.localeCompare(b.tag));

const toSlug = (tag: string) => tag.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Tags | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<ThemeScript />
	</head>
	<body>
		<Header />
		<main>
			<div class="page-shell tags-shell">
				<section class="tag-index pixel-panel" aria-label="All tags">
					<div class="tag-index-header">
						<p class="eyebrow">Index</p>
						<h2 class="section-title" data-index-title>{tags.length} tags · {posts.length} posts</h2>
					</div>
					<ul class="tag-cloud" role="tablist">
						<li>
							<button
								type="button"
								class="tag-cloud-link tag-all active"
								data-filter="all"
								aria-pressed="true"
							>
								<span class="tag-cloud-name">All</span>
								<span class="tag-cloud-count">{posts.length}</span>
							</button>
						</li>
						{tags.map(({ tag, count }) => (
							<li>
								<button
									type="button"
									class="tag-cloud-link"
									data-filter={tag}
									data-count={count}
									aria-pressed="false"
								>
									<span class="tag-cloud-name">#{tag}</span>
									<span class="tag-cloud-count">{count}</span>
								</button>
							</li>
						))}
					</ul>
				</section>

				{tags.map(({ tag, posts: tagPosts, count }) => (
					<section class="tag-block" data-tag-block={tag} id={`tag-${toSlug(tag)}`}>
						<header class="tag-block-header">
							<h2 class="tag-block-title">#{tag}</h2>
							<span class="tag-block-count">{count} {count === 1 ? 'post' : 'posts'}</span>
						</header>
						<ol class="tag-post-list">
							{tagPosts.map((post) => (
								<li>
									<a class="tag-post-link" href={`/posts/${post.id}/`}>
										<time class="tag-post-date">
											<FormattedDate date={post.data.pubDate} />
										</time>
										<span class="tag-post-title">{post.data.title}</span>
									</a>
								</li>
							))}
						</ol>
					</section>
				))}
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	.tags-shell {
		gap: 1.4rem;
	}

	.tag-index {
		padding: 1.2rem;
	}

	.tag-index-header {
		margin-bottom: 0.9rem;
	}

	.tag-cloud {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem 0.6rem;
	}

	.tag-cloud-link {
		display: inline-flex;
		align-items: baseline;
		gap: 0.4rem;
		padding: 0.35rem 0.7rem;
		border: 1.5px solid var(--line-soft);
		border-radius: 2px;
		background: var(--panel);
		color: var(--ink);
		text-decoration: none;
		font: inherit;
		cursor: pointer;
		transition:
			transform 120ms ease,
			border-color 120ms ease,
			background-color 120ms ease;
	}

	.tag-cloud-link.active {
		border-color: var(--line);
		background: var(--accent-soft);
	}

	.tag-cloud-link.active .tag-cloud-count {
		color: var(--ink);
	}

	.tag-cloud-link:hover {
		transform: translate(-1px, -1px);
		border-color: var(--line);
		background: color-mix(in srgb, var(--accent-soft) 55%, var(--panel));
	}

	.tag-cloud-name {
		font-size: 0.9rem;
		font-weight: 700;
		letter-spacing: 0.02em;
	}

	.tag-cloud-count {
		font-size: 0.72rem;
		font-weight: 700;
		letter-spacing: 0.04em;
		color: var(--muted);
		font-variant-numeric: tabular-nums;
	}

	.tag-block[hidden] {
		display: none;
	}

	.tag-block {
		scroll-margin-top: 1rem;
	}

	.tag-block-header {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: 0.75rem;
		margin: 0 0 0.55rem;
		padding-bottom: 0.35rem;
		border-bottom: 1.5px solid color-mix(in srgb, var(--line) 30%, transparent);
	}

	.tag-block-title {
		margin: 0;
		font-size: 1.1rem;
		letter-spacing: -0.005em;
	}

	.tag-block-count {
		font-size: 0.72rem;
		font-weight: 700;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--muted);
		font-variant-numeric: tabular-nums;
	}

	.tag-post-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: grid;
		gap: 0.15rem;
	}

	.tag-post-link {
		display: grid;
		grid-template-columns: 6.5rem 1fr;
		align-items: baseline;
		gap: 0.8rem;
		padding: 0.5rem 0.6rem;
		color: var(--ink);
		text-decoration: none;
		border-radius: 2px;
		transition: background-color 120ms ease, transform 120ms ease;
	}

	.tag-post-link:hover {
		background: color-mix(in srgb, var(--accent-soft) 40%, transparent);
		transform: translateX(2px);
	}

	.tag-post-date {
		font-size: 0.74rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--muted);
		font-variant-numeric: tabular-nums;
		white-space: nowrap;
	}

	.tag-post-title {
		font-size: 0.98rem;
		line-height: 1.4;
	}

	@media (min-width: 760px) {
		.tag-index {
			padding: 1.4rem;
		}
	}

	@media (max-width: 520px) {
		.tag-post-link {
			grid-template-columns: 1fr;
			gap: 0.15rem;
		}
	}
</style>

<script>
	const buttons = Array.from(document.querySelectorAll('[data-filter]'));
	const blocks = Array.from(document.querySelectorAll('[data-tag-block]'));
	const indexTitle = document.querySelector('[data-index-title]');
	const originalTitle = indexTitle?.textContent ?? '';

	const applyFilter = (selected) => {
		for (const btn of buttons) {
			const active = btn.dataset.filter === selected;
			btn.classList.toggle('active', active);
			btn.setAttribute('aria-pressed', String(active));
		}

		let visibleCount = 0;
		let postCount = 0;
		for (const block of blocks) {
			const tag = block.dataset.tagBlock;
			const match = selected === 'all' || tag === selected;
			block.hidden = !match;
			if (match) {
				visibleCount += 1;
				postCount += block.querySelectorAll('.tag-post-link').length;
			}
		}

		if (indexTitle) {
			indexTitle.textContent = selected === 'all'
				? originalTitle
				: `#${selected} · ${postCount} ${postCount === 1 ? 'post' : 'posts'}`;
		}
	};

	for (const btn of buttons) {
		btn.addEventListener('click', () => {
			applyFilter(btn.dataset.filter || 'all');
			window.scrollTo({ top: 0, behavior: 'smooth' });
		});
	}
</script>
