---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import ThemeScript from '../../components/ThemeScript.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<ThemeScript />
	</head>
	<body>
		<Header />
		<main>
			<div class="page-shell">
				<section class="search-shell">
					<div class="search-field">
						<svg
							class="search-icon"
							viewBox="0 0 24 24"
							width="16"
							height="16"
							fill="none"
							stroke="currentColor"
							stroke-width="2"
							stroke-linecap="round"
							stroke-linejoin="round"
							aria-hidden="true"
						>
							<circle cx="11" cy="11" r="7"></circle>
							<path d="m20 20-3.5-3.5"></path>
						</svg>
						<input
							id="post-search"
							class="search-input"
							type="search"
							placeholder="Search posts, tags, or keywords"
							aria-label="Search posts"
						/>
					</div>
					<p id="search-empty" class="search-empty" hidden>No matching posts.</p>
				</section>
				<section class="post-grid" id="post-grid">
					{
						posts.map((post) => (
							<article
								class="post-item pixel-panel"
								data-post-card
								data-search={`${post.data.title} ${post.data.description} ${post.data.tags.join(' ')}`.toLowerCase()}
							>
								<a class="post-link" href={`/posts/${post.id}/`}>
									<p class="date">
										<FormattedDate date={post.data.pubDate} />
									</p>
									<h2 class="title">{post.data.title}</h2>
									<p class="description">{post.data.description}</p>
									<div class="card-footer">
										<ul class="category-list">
											{post.data.tags.map((tag) => (
												<li class="category">#{tag}</li>
											))}
										</ul>
									</div>
								</a>
							</article>
						))
					}
				</section>
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	.post-item {
		padding: 1.2rem;
		display: flex;
	}

	.post-item[hidden] {
		display: none;
	}

	.post-link {
		display: flex;
		flex-direction: column;
		width: 100%;
		text-decoration: none;
	}

	.date {
		margin: 0 0 0.55rem;
		font-size: 0.78rem;
		font-weight: 700;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--muted);
	}

	.search-field {
		position: relative;
		transition: transform 120ms ease;
	}

	.search-field .search-icon {
		position: absolute;
		top: 50%;
		left: 0.85rem;
		width: 1rem;
		height: 1rem;
		color: var(--muted);
		transform: translateY(-50%);
		pointer-events: none;
		transition: color 120ms ease;
	}

	.search-field .search-input {
		padding-left: 2.4rem;
	}

	.search-field:focus-within {
		transform: translate(-1px, -1px);
	}

	.search-field:focus-within .search-icon {
		color: var(--ink);
	}

	.search-field:focus-within .search-input {
		background: var(--panel);
		border-color: var(--line);
		box-shadow: 4px 4px 0 var(--shadow);
		outline: 2px solid color-mix(in srgb, var(--accent) 42%, transparent);
		outline-offset: 2px;
	}

	.post-grid {
		display: grid;
		gap: 1rem;
	}

	.category-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
	}

	.category {
		display: inline-flex;
		align-items: center;
		padding: 0.18rem 0.5rem;
		background: var(--accent-soft);
		color: var(--ink);
		font-size: 0.72rem;
		font-weight: 700;
		letter-spacing: 0.03em;
		border-radius: 2px;
	}

	.title {
		margin: 0 0 0.55rem;
		font-size: 1.25rem;
		line-height: 1.3;
	}

	.description {
		margin: 0 0 1rem;
		color: var(--muted);
	}

	.card-footer {
		margin-top: auto;
		padding-top: 0.6rem;
		border-top: 1px solid color-mix(in srgb, var(--line) 12%, transparent);
		display: flex;
		align-items: center;
	}

	.post-item {
		transition:
			transform 120ms ease,
			box-shadow 120ms ease;
	}

	.post-item:hover {
		transform: translate(-1px, -1px);
		box-shadow: 6px 6px 0 var(--shadow);
	}

	@media (min-width: 760px) {
		.post-item {
			padding: 1.4rem;
		}

		.post-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}
</style>

<script>
	const searchInput = document.querySelector('#post-search');
	const searchEmpty = document.querySelector('#search-empty');
	const cards = Array.from(document.querySelectorAll('[data-post-card]'));

	if (searchInput && searchEmpty) {
		searchInput.addEventListener('input', (event) => {
			const query = event.currentTarget.value.trim().toLowerCase();
			let visibleCount = 0;

			for (const card of cards) {
				const haystack = card.dataset.search || '';
				const matched = !query || haystack.includes(query);
				card.hidden = !matched;
				if (matched) visibleCount += 1;
			}

			searchEmpty.hidden = visibleCount !== 0;
		});
	}
</script>
