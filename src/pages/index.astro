---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import ThemeScript from '../components/ThemeScript.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<ThemeScript />
	</head>
	<body>
		<Header />
		<main>
			<div class="page-shell">
				<section class="hero pixel-panel">
					<div class="hero-copy">
						<p class="eyebrow">SummerGua / Notes</p>
						<h1>记录前端、JavaScript 和日常学习笔记。</h1>
						<p class="hero-text">一个用 Markdown 写内容的个人博客，目前收录的是正在整理的技术笔记。</p>
						<div class="hero-actions">
							<a class="button-link" href="/blog">进入 Posts</a>
							<a class="button-link ghost" href="/archive">打开 Archive</a>
						</div>
					</div>
					<div class="status-panel">
						<p class="eyebrow">Current Focus</p>
						<ul class="status-list">
							<li>Markdown 写作</li>
							<li>JavaScript 笔记整理</li>
							<li>移动端优先阅读体验</li>
							<li>极简像素风界面</li>
						</ul>
					</div>
				</section>

				<section class="intro-grid">
					<article class="pixel-panel intro-card">
						<p class="eyebrow">Now Reading</p>
						<h2 class="section-title">最近在写</h2>
						<p>目前这站以技术笔记为主，先从 Web Workers 这样的基础主题开始慢慢补全。</p>
					</article>
					<article class="pixel-panel intro-card">
						<p class="eyebrow">Site Style</p>
						<h2 class="section-title">页面风格</h2>
						<p>界面保持极简和硬边框节奏，重点还是让文章在手机和桌面上都容易阅读。</p>
					</article>
				</section>

				<section class="recent-section pixel-panel">
					<div class="recent-header">
						<div>
							<p class="eyebrow">Latest Post</p>
							<h2 class="section-title">最近文章</h2>
						</div>
						<a class="button-link ghost recent-link" href="/blog">查看 Posts</a>
					</div>
					<div class="post-list">
						{
							posts.map((post) => (
								<a class="post-card" href={`/blog/${post.id}/`}>
									<div class="post-meta">
										<span class="post-category">{post.data.category}</span>
										<p class="post-date">{post.data.pubDate.toLocaleDateString('en-US')}</p>
									</div>
									<h3>{post.data.title}</h3>
									<p class="post-description">{post.data.description}</p>
								</a>
							))
						}
					</div>
				</section>
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	.hero,
	.recent-section,
	.intro-card {
		padding: 1.2rem;
	}

	.hero {
		display: grid;
		gap: 1rem;
	}

	.hero-text {
		max-width: 36rem;
		font-size: 1rem;
		color: var(--muted);
	}

	.hero-actions {
		display: grid;
		gap: 0.75rem;
		margin-top: 1.5rem;
	}

	.status-panel {
		padding: 1rem;
		border: 2px dashed var(--line);
		background: rgba(232, 220, 196, 0.35);
	}

	.status-list {
		margin: 0.8rem 0 0;
		padding-left: 1.1rem;
	}

	.status-list li + li {
		margin-top: 0.45rem;
	}

	.intro-grid {
		display: grid;
		gap: 1rem;
	}

	.recent-header {
		display: grid;
		gap: 1rem;
		margin-bottom: 1rem;
	}

	.post-list {
		display: grid;
		gap: 0.9rem;
	}

	.post-card {
		display: block;
		padding: 1rem;
		border: 2px solid var(--line);
		background: rgba(255, 249, 236, 0.65);
		text-decoration: none;
		transition:
			transform 120ms ease,
			box-shadow 120ms ease,
			background-color 120ms ease;
	}

	.post-card:hover {
		transform: translate(-1px, -1px);
		box-shadow: 4px 4px 0 var(--shadow);
		background: var(--panel);
	}

	.post-date {
		margin: 0;
		font-size: 0.78rem;
		font-weight: 700;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--muted);
	}

	.post-meta {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.5rem 0.75rem;
		margin-bottom: 0.45rem;
	}

	.post-category {
		display: inline-flex;
		align-items: center;
		padding: 0.18rem 0.45rem;
		border: 1px solid var(--line);
		background: var(--accent-soft);
		font-size: 0.72rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.post-description {
		margin-bottom: 0;
		color: var(--muted);
	}

	@media (min-width: 760px) {
		.hero,
		.recent-section,
		.intro-card {
			padding: 1.5rem;
		}

		.hero {
			grid-template-columns: minmax(0, 1.7fr) minmax(16rem, 0.9fr);
			align-items: end;
		}

		.hero-actions {
			display: flex;
			flex-wrap: wrap;
		}

		.intro-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}

		.recent-header {
			grid-template-columns: minmax(0, 1fr) auto;
			align-items: end;
		}

		.post-list {
			grid-template-columns: repeat(3, minmax(0, 1fr));
		}

		.recent-link {
			width: auto;
		}
	}
</style>
