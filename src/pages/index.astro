---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import ThemeScript from '../components/ThemeScript.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<ThemeScript />
	</head>
	<body>
		<Header />
		<main>
			<div class="page-shell">
				<section class="intro-section pixel-panel">
					<p class="eyebrow">Hello</p>
					<h1 class="intro-title">I&rsquo;m Shilong Shu.</h1>
					<p class="intro-body">
						A frontend engineer who enjoys picking apart tools and writing them back up in plain
						words. This is where I keep short notes on JavaScript, browsers, and the occasional
						build-tool rabbit hole.
					</p>
					<div class="intro-actions">
						<a class="button-link" href="/posts">Read the blog</a>
						<a class="button-link ghost" href="/about">About me</a>
					</div>
				</section>
				<section class="recent-section pixel-panel">
					<div class="recent-header">
						<div>
							<p class="eyebrow">Latest</p>
							<h2 class="section-title">Recent posts</h2>
						</div>
						<a class="button-link ghost recent-link" href="/posts">View all posts</a>
					</div>
					<div class="post-list">
						{
							posts.map((post) => (
								<a class="post-card" href={`/posts/${post.id}/`}>
									<div class="post-meta">
										<ul class="post-category-list">
											{post.data.tags.map((tag) => (
												<li class="post-category">#{tag}</li>
											))}
										</ul>
										<p class="post-date">{post.data.pubDate.toLocaleDateString('en-US')}</p>
									</div>
									<h3>{post.data.title}</h3>
									<p class="post-description">{post.data.description}</p>
								</a>
							))
						}
					</div>
				</section>
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	.recent-section {
		padding: 1.2rem;
	}

	.intro-section {
		padding: 1.4rem 1.2rem;
		display: grid;
		gap: 0.55rem;
	}

	.intro-title {
		margin: 0.15rem 0 0.2rem;
		font-size: clamp(1.8rem, 4.2vw, 2.6rem);
		letter-spacing: -0.03em;
		line-height: 1.1;
	}

	.intro-body {
		margin: 0;
		max-width: 42rem;
		color: var(--muted);
		font-size: 1rem;
		line-height: 1.65;
	}

	.intro-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.6rem;
		margin-top: 0.4rem;
	}

	.recent-header {
		display: grid;
		gap: 1rem;
		margin-bottom: 1rem;
	}

	.post-list {
		display: grid;
		gap: 0.9rem;
	}

	.post-card {
		display: block;
		padding: 1rem;
		border: 1px solid var(--line-soft);
		background: var(--panel-soft);
		color: var(--ink);
		text-decoration: none;
		border-radius: 2px;
		transition:
			transform 120ms ease,
			border-color 120ms ease,
			background-color 120ms ease;
	}

	.post-card:hover {
		transform: translate(-1px, -1px);
		border-color: var(--line);
		background: color-mix(in srgb, var(--accent-soft) 40%, var(--panel));
	}

	.post-date {
		margin: 0;
		font-size: 0.78rem;
		font-weight: 700;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--muted);
	}

	.post-meta {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.5rem 0.75rem;
		margin-bottom: 0.45rem;
	}

	.post-category-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
	}

	.post-category {
		display: inline-flex;
		align-items: center;
		padding: 0.18rem 0.5rem;
		background: var(--accent-soft);
		color: var(--ink);
		font-size: 0.72rem;
		font-weight: 700;
		letter-spacing: 0.03em;
		border-radius: 2px;
	}

	.post-description {
		margin-bottom: 0;
		color: var(--muted);
	}

	@media (min-width: 760px) {
		.recent-section {
			padding: 1.5rem;
		}

		.intro-section {
			padding: 1.9rem 1.6rem;
		}

		.recent-header {
			grid-template-columns: minmax(0, 1fr) auto;
			align-items: end;
		}

		.post-list {
			grid-template-columns: repeat(3, minmax(0, 1fr));
		}

		.recent-link {
			width: auto;
		}
	}
</style>
