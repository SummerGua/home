---
import Layout from '../layouts/BlogPost.astro';
---

<Layout
	title="About"
	description="A short introduction to Shilong Shu and this blog."
	pubDate={new Date('July 01 2026')}
	showBack={false}
	showHero={false}
	wide
>
	<div class="resume-layout">
		<aside class="resume-aside" aria-label="Profile photo">
			<img
				class="avatar"
				src="/images/avatar.jpeg"
				alt="Pixel avatar of Shilong Shu"
				width="160"
				height="160"
			/>
			<p class="email-title">
				<a class="email-link" href="mailto:covey.shu@gmail.com">covey.shu@gmail.com</a>
			</p>
			<p class="profile-location" aria-label="Location">
				<svg
					class="location-icon"
					viewBox="0 0 24 24"
					width="13"
					height="13"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					stroke-linecap="round"
					stroke-linejoin="round"
					aria-hidden="true"
				>
					<path d="M20 10c0 4.5-8 11-8 11s-8-6.5-8-11a8 8 0 1 1 16 0Z"></path>
					<circle cx="12" cy="10" r="3"></circle>
				</svg>
				<span>Shanghai</span>
			</p>
		</aside>

		<div class="resume-main">
			<section class="summary">
				<p class="lede">
					Hi, I&rsquo;m <strong>Shilong Shu</strong>, a frontend engineer at ByteDance.
					<br />
					I&rsquo;m working toward becoming a well-rounded full-stack engineer, and this is
					where I keep technical notes and things I&rsquo;m learning along the way.
				</p>
			</section>

			<section class="timeline-section">
				<h2 class="section-heading">Experience</h2>
				<ol class="timeline">
					<li class="timeline-item" data-current>
						<div class="timeline-marker" aria-hidden="true"></div>
						<div class="timeline-content">
							<div class="timeline-head">
								<h3 class="timeline-title">ByteDance</h3>
								<span class="timeline-date">2025.06 &ndash; Present</span>
							</div>
							<p class="timeline-role">Frontend Engineer</p>
						</div>
					</li>
					<li class="timeline-item">
						<div class="timeline-marker" aria-hidden="true"></div>
						<div class="timeline-content">
							<div class="timeline-head">
								<h3 class="timeline-title">ByteDance</h3>
								<span class="timeline-date">2024.11 &ndash; 2025.03</span>
							</div>
							<p class="timeline-role">Frontend Engineer Intern</p>
						</div>
					</li>
					<li class="timeline-item">
						<div class="timeline-marker" aria-hidden="true"></div>
						<div class="timeline-content">
							<div class="timeline-head">
								<h3 class="timeline-title">Xiaohongshu</h3>
								<span class="timeline-date">2024.03 &ndash; 2024.08</span>
							</div>
							<p class="timeline-role">Frontend Engineer Intern</p>
						</div>
					</li>
				</ol>
			</section>

			<section class="timeline-section">
				<h2 class="section-heading">Education</h2>
				<ol class="timeline">
					<li class="timeline-item">
						<div class="timeline-marker" aria-hidden="true"></div>
						<div class="timeline-content">
							<div class="timeline-head">
								<h3 class="timeline-title">Nanjing Normal University</h3>
								<span class="timeline-date">2022 &ndash; 2025</span>
							</div>
							<p class="timeline-role">M.Ed. in Educational Information Engineering</p>
							<article class="pub">
								<p class="pub-label">Publication</p>
								<h4 class="pub-title">
									<a
										href="https://link.springer.com/chapter/10.1007/978-981-97-2259-4_30"
										target="_blank"
										rel="noopener noreferrer"
									>
										Improving Knowledge Tracing via Considering Students&rsquo; Interaction Patterns
									</a>
								</h4>
								<p class="pub-authors">
									<span class="pub-me">Shilong Shu</span>, Liting Wang, Junhua Tian
								</p>
								<p class="pub-venue">
									<span class="pub-venue-name">PAKDD 2024</span>
									<span class="pub-badge">CCF-C</span>
								</p>
							</article>
						</div>
					</li>
					<li class="timeline-item">
						<div class="timeline-marker" aria-hidden="true"></div>
						<div class="timeline-content">
							<div class="timeline-head">
								<h3 class="timeline-title">Chongqing University of Posts and Telecommunications</h3>
								<span class="timeline-date">2018 &ndash; 2022</span>
							</div>
							<p class="timeline-role">B.Eng. in Information Engineering</p>
						</div>
					</li>
				</ol>
			</section>
		</div>
	</div>
</Layout>

<style>
	.resume-layout {
		display: grid;
		grid-template-columns: 13rem minmax(0, 1fr);
		align-items: start;
		gap: 1.5rem;
		max-width: 52rem;
		margin: 0 auto;
	}

	.resume-aside {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 0.75rem;
		width: 13rem;
		min-width: 0;
	}

	.resume-main {
		min-width: 0;
	}

	.summary {
		margin: 0 0 2rem;
	}

	.avatar {
		width: 7rem;
		aspect-ratio: 1;
		height: auto;
		object-fit: cover;
		border: 1.5px solid var(--line);
		border-radius: 50%;
		background: var(--panel);
		box-shadow: 0 0 0 4px var(--panel), 5px 5px 0 var(--shadow);
		image-rendering: pixelated;
		transform-origin: 45% 55%;
		transition: box-shadow 160ms ease;
		will-change: transform;
	}

	.email-title {
		margin: 0 !important;
		font-size: 0.9rem;
		line-height: 1.4;
		letter-spacing: -0.005em;
		text-align: center;
	}

	.profile-location {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		margin: -0.25rem 0 0 !important;
		color: var(--ink);
		font-size: 0.9rem;
		line-height: 1;
	}

	.location-icon {
		display: block;
		flex: 0 0 auto;
		width: 0.9em;
		height: 0.9em;
		color: var(--accent);
	}

	.avatar:hover {
		animation: coaster-nudge 620ms cubic-bezier(.2, .8, .2, 1) both;
		box-shadow: 0 0 0 4px var(--panel), 2px 7px 0 var(--shadow);
	}

	.avatar:active {
		transform: translate(0.28rem, 0.12rem) rotate(3deg) scale(0.98);
		box-shadow: 0 0 0 4px var(--panel), 1px 3px 0 var(--shadow);
	}

	@keyframes coaster-nudge {
		0% {
			transform: translate(0, 0) rotate(0deg);
		}
		38% {
			transform: translate(0.35rem, -0.16rem) rotate(8deg);
		}
		68% {
			transform: translate(0.2rem, -0.06rem) rotate(4deg);
		}
		100% {
			transform: translate(0.28rem, -0.1rem) rotate(5deg);
		}
	}

	.lede {
		margin: 0 !important;
		font-size: 1.08rem;
		line-height: 1.7;
		color: var(--ink);
	}

	.section-heading {
		margin: 2rem 0 0.9rem !important;
		font-size: 0.78rem;
		font-weight: 700;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: var(--muted);
	}

	.timeline {
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.timeline-item {
		position: relative;
		padding: 0 0 1rem 1.6rem;
	}

	.timeline-item::before {
		content: '';
		position: absolute;
		left: 0.28rem;
		top: 0.6rem;
		bottom: -0.2rem;
		width: 2px;
		background: color-mix(in srgb, var(--line) 60%, transparent);
	}

	.timeline-item:last-child::before {
		display: none;
	}

	.timeline-item:last-child {
		padding-bottom: 0;
	}

	.timeline-marker {
		position: absolute;
		left: 0;
		top: 0.35rem;
		width: 0.65rem;
		height: 0.65rem;
		background: var(--accent);
		border: 2px solid var(--panel);
		box-shadow: 0 0 0 2px var(--line);
		z-index: 1;
	}

	.timeline-item[data-current] .timeline-marker {
		animation: pulse 2s ease-in-out infinite;
	}

	@keyframes pulse {
		0%, 100% { box-shadow: 0 0 0 2px var(--line), 0 0 0 4px transparent; }
		50% { box-shadow: 0 0 0 2px var(--line), 0 0 0 6px color-mix(in srgb, var(--accent) 25%, transparent); }
	}

	.timeline-head {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: 0.75rem;
		min-width: 0;
	}

	.timeline-title {
		margin: 0 !important;
		font-size: 0.98rem;
		line-height: 1.3;
		letter-spacing: -0.005em;
	}

	.timeline-date {
		font-size: 0.74rem;
		font-weight: 700;
		letter-spacing: 0.1em;
		color: var(--muted);
		font-variant-numeric: tabular-nums;
		white-space: nowrap;
	}

	.timeline-role {
		margin: 0.1rem 0 0;
		font-size: 0.86rem;
		color: var(--muted);
		line-height: 1.4;
	}

	.pub {
		margin-top: 0.65rem;
		padding: 0.6rem 0.8rem;
		border-left: 3px solid var(--accent);
		background: color-mix(in srgb, var(--accent-soft) 22%, transparent);
		border-radius: 0 2px 2px 0;
	}

	.pub-label {
		margin: 0 0 0.25rem;
		font-size: 0.62rem;
		font-weight: 700;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: var(--muted);
	}

	.pub-title {
		margin: 0 !important;
		font-size: 0.9rem;
		line-height: 1.4;
		letter-spacing: -0.005em;
	}

	.pub-title a,
	.email-title .email-link {
		color: inherit;
		text-decoration: none;
		border-bottom: 1.5px solid transparent;
		transition: border-color 140ms ease, color 140ms ease;
	}

	.pub-title a:hover,
	.email-title .email-link:hover {
		border-bottom-color: var(--accent);
	}

	.pub-title a::after {
		content: ' ↗';
		font-size: 0.72em;
		color: var(--muted);
		letter-spacing: 0;
	}

	.pub-authors {
		margin: 0.35rem 0 0.3rem;
		font-size: 0.86rem;
		color: var(--ink);
		line-height: 1.4;
	}

	.pub-me {
		text-decoration: underline;
		text-decoration-color: var(--accent);
		text-decoration-thickness: 2px;
		text-decoration-skip-ink: none;
		text-underline-offset: 0.14em;
	}

	.pub-venue {
		margin: 0;
		display: flex;
		flex-wrap: wrap;
		gap: 0.25rem 0.45rem;
		font-size: 0.78rem;
		color: var(--muted);
		line-height: 1.45;
	}

	.pub-venue-name {
		font-weight: 700;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: var(--ink);
	}

	.pub-badge {
		display: inline-flex;
		align-items: center;
		padding: 0.06rem 0.36rem;
		border: 1px solid var(--accent);
		border-radius: 2px;
		background: var(--accent-soft);
		color: var(--ink);
		font-size: 0.66rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		line-height: 1.25;
		text-transform: uppercase;
	}

	.pub-sep {
		opacity: 0.55;
	}

	@media (max-width: 520px) {
		.resume-layout {
			grid-template-columns: 1fr;
			justify-items: start;
			gap: 1rem;
		}

		.resume-aside {
			align-items: flex-start;
			justify-content: flex-start;
			width: min(100%, 13rem);
		}

		.avatar {
			width: 7rem;
		}

		.timeline-head {
			display: grid;
			grid-template-columns: 1fr;
			gap: 0.15rem;
		}
	}
</style>
