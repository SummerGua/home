---
import Layout from '../layouts/BlogPost.astro';
---

<Layout
	title="About"
	description="A short introduction to Shilong Shu and this blog."
	pubDate={new Date('July 01 2026')}
	showBack={false}
	showHero={false}
>
	<section class="intro">
		<p class="lede">
			Hi, I&rsquo;m <strong>Shilong Shu</strong> — a frontend engineer at ByteDance.
			This is where I keep technical notes and things I&rsquo;m learning along the way.
		</p>
	</section>

	<section class="timeline-section">
		<h2 class="section-heading">Experience</h2>
		<ol class="timeline">
			<li class="timeline-item" data-current>
				<div class="timeline-marker" aria-hidden="true"></div>
				<div class="timeline-content">
					<div class="timeline-head">
						<h3 class="timeline-title">ByteDance</h3>
						<span class="timeline-date">2025.06 &ndash; Present</span>
					</div>
					<p class="timeline-role">Frontend Engineer</p>
				</div>
			</li>
			<li class="timeline-item">
				<div class="timeline-marker" aria-hidden="true"></div>
				<div class="timeline-content">
					<div class="timeline-head">
						<h3 class="timeline-title">ByteDance</h3>
						<span class="timeline-date">2024.11 &ndash; 2025.03</span>
					</div>
					<p class="timeline-role">Frontend Engineer Intern</p>
				</div>
			</li>
			<li class="timeline-item">
				<div class="timeline-marker" aria-hidden="true"></div>
				<div class="timeline-content">
					<div class="timeline-head">
						<h3 class="timeline-title">Xiaohongshu</h3>
						<span class="timeline-date">2024.03 &ndash; 2024.08</span>
					</div>
					<p class="timeline-role">Frontend Engineer Intern</p>
				</div>
			</li>
		</ol>
	</section>

	<section class="timeline-section">
		<h2 class="section-heading">Education</h2>
		<ol class="timeline">
			<li class="timeline-item">
				<div class="timeline-marker" aria-hidden="true"></div>
				<div class="timeline-content">
					<div class="timeline-head">
						<h3 class="timeline-title">Nanjing Normal University</h3>
						<span class="timeline-date">2022 &ndash; 2025</span>
					</div>
					<p class="timeline-role">M.Ed. in Educational Information Engineering</p>
					<article class="pub">
						<p class="pub-label">Publication</p>
						<h4 class="pub-title">
							<a
								href="https://link.springer.com/chapter/10.1007/978-981-97-2259-4_30"
								target="_blank"
								rel="noopener noreferrer"
							>
								Improving Knowledge Tracing via Considering Students&rsquo; Interaction Patterns
							</a>
						</h4>
						<p class="pub-authors">
							<span class="pub-me">Shilong Shu</span>, Liting Wang, Junhua Tian
						</p>
						<p class="pub-venue">
							<span class="pub-venue-name">PAKDD 2024</span>
							<span class="pub-badge">CCF-C</span>
						</p>
					</article>
				</div>
			</li>
			<li class="timeline-item">
				<div class="timeline-marker" aria-hidden="true"></div>
				<div class="timeline-content">
					<div class="timeline-head">
						<h3 class="timeline-title">Chongqing University of Posts and Telecommunications</h3>
						<span class="timeline-date">2018 &ndash; 2022</span>
					</div>
					<p class="timeline-role">B.Eng. in Information Engineering</p>
				</div>
			</li>
		</ol>
	</section>
</Layout>

<style>
	.intro {
		margin: 0 0 2rem;
	}

	.lede {
		max-width: 42rem;
		margin: 0;
		font-size: 1.08rem;
		line-height: 1.7;
		color: var(--ink);
	}

	.section-heading {
		margin: 2rem 0 0.9rem !important;
		font-size: 0.78rem;
		font-weight: 700;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: var(--muted);
	}

	.timeline {
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.timeline-item {
		position: relative;
		padding: 0 0 1rem 1.6rem;
	}

	.timeline-item::before {
		content: '';
		position: absolute;
		left: 0.28rem;
		top: 0.6rem;
		bottom: -0.2rem;
		width: 2px;
		background: color-mix(in srgb, var(--line) 60%, transparent);
	}

	.timeline-item:last-child::before {
		display: none;
	}

	.timeline-item:last-child {
		padding-bottom: 0;
	}

	.timeline-marker {
		position: absolute;
		left: 0;
		top: 0.35rem;
		width: 0.65rem;
		height: 0.65rem;
		background: var(--accent);
		border: 2px solid var(--panel);
		box-shadow: 0 0 0 2px var(--line);
		z-index: 1;
	}

	.timeline-item[data-current] .timeline-marker {
		animation: pulse 2s ease-in-out infinite;
	}

	@keyframes pulse {
		0%, 100% { box-shadow: 0 0 0 2px var(--line), 0 0 0 4px transparent; }
		50% { box-shadow: 0 0 0 2px var(--line), 0 0 0 6px color-mix(in srgb, var(--accent) 25%, transparent); }
	}

	.timeline-head {
		display: flex;
		flex-wrap: wrap;
		align-items: baseline;
		justify-content: space-between;
		gap: 0.15rem 0.9rem;
	}

	.timeline-title {
		margin: 0 !important;
		font-size: 0.98rem;
		line-height: 1.3;
		letter-spacing: -0.005em;
	}

	.timeline-date {
		font-size: 0.74rem;
		font-weight: 700;
		letter-spacing: 0.1em;
		color: var(--muted);
		font-variant-numeric: tabular-nums;
		white-space: nowrap;
	}

	.timeline-role {
		margin: 0.1rem 0 0;
		font-size: 0.86rem;
		color: var(--muted);
		line-height: 1.4;
	}

	.pub {
		margin-top: 0.65rem;
		padding: 0.6rem 0.8rem;
		border-left: 3px solid var(--accent);
		background: color-mix(in srgb, var(--accent-soft) 22%, transparent);
		border-radius: 0 2px 2px 0;
	}

	.pub-label {
		margin: 0 0 0.25rem;
		font-size: 0.62rem;
		font-weight: 700;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: var(--muted);
	}

	.pub-title {
		margin: 0 !important;
		font-size: 0.9rem;
		line-height: 1.4;
		letter-spacing: -0.005em;
	}

	.pub-title a {
		color: inherit;
		text-decoration: none;
		border-bottom: 1.5px solid transparent;
		transition: border-color 140ms ease, color 140ms ease;
	}

	.pub-title a:hover {
		border-bottom-color: var(--accent);
	}

	.pub-title a::after {
		content: ' ↗';
		font-size: 0.72em;
		color: var(--muted);
		letter-spacing: 0;
	}

	.pub-authors {
		margin: 0.35rem 0 0.3rem;
		font-size: 0.86rem;
		color: var(--ink);
		line-height: 1.4;
	}

	.pub-me {
		text-decoration: underline;
		text-decoration-color: var(--accent);
		text-decoration-thickness: 2px;
		text-decoration-skip-ink: none;
		text-underline-offset: 0.14em;
	}

	.pub-venue {
		margin: 0;
		display: flex;
		flex-wrap: wrap;
		gap: 0.25rem 0.45rem;
		font-size: 0.78rem;
		color: var(--muted);
		line-height: 1.45;
	}

	.pub-venue-name {
		font-weight: 700;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: var(--ink);
	}

	.pub-badge {
		display: inline-flex;
		align-items: center;
		padding: 0.06rem 0.36rem;
		border: 1px solid var(--accent);
		border-radius: 2px;
		background: var(--accent-soft);
		color: var(--ink);
		font-size: 0.66rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		line-height: 1.25;
		text-transform: uppercase;
	}

	.pub-sep {
		opacity: 0.55;
	}
</style>
