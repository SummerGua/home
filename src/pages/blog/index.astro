---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import ThemeScript from '../../components/ThemeScript.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<ThemeScript />
	</head>
	<body>
		<Header />
		<main>
			<div class="page-shell">
				<section class="search-shell">
					<input
						id="post-search"
						class="search-input"
						type="search"
						placeholder="Search posts, categories, or keywords"
						aria-label="Search posts"
					/>
					<p id="search-empty" class="search-empty" hidden>没有匹配结果。</p>
				</section>
				<section class="post-grid" id="post-grid">
					{
						posts.map((post) => (
							<article
								class="post-item pixel-panel"
								data-post-card
								data-search={`${post.data.title} ${post.data.description} ${post.data.category}`.toLowerCase()}
							>
								<a class="post-link" href={`/blog/${post.id}/`}>
									<div class="meta-row">
										<span class="category">{post.data.category}</span>
										<p class="date">
											<FormattedDate date={post.data.pubDate} />
										</p>
									</div>
									<h2 class="title">{post.data.title}</h2>
									<p class="description">{post.data.description}</p>
									<span class="read-more">Read entry</span>
								</a>
							</article>
						))
					}
				</section>
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	.post-item {
		padding: 1.2rem;
	}

	.post-grid {
		display: grid;
		gap: 1rem;
	}

	.post-link {
		display: block;
		text-decoration: none;
	}

	.date {
		margin: 0;
		font-size: 0.78rem;
		font-weight: 700;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--muted);
	}

	.meta-row {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.5rem 0.75rem;
		margin-bottom: 0.6rem;
	}

	.category {
		display: inline-flex;
		align-items: center;
		padding: 0.18rem 0.45rem;
		border: 1px solid var(--line);
		background: var(--accent-soft);
		font-size: 0.72rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.title {
		margin-bottom: 0.7rem;
		font-size: 1.45rem;
	}

	.description {
		color: var(--muted);
	}

	.read-more {
		display: inline-block;
		margin-top: 0.4rem;
		font-size: 0.82rem;
		font-weight: 700;
		letter-spacing: 0.1em;
		text-transform: uppercase;
	}

	.post-item {
		transition:
			transform 120ms ease,
			box-shadow 120ms ease;
	}

	.post-item:hover {
		transform: translate(-1px, -1px);
		box-shadow: 8px 8px 0 var(--shadow);
	}

	@media (min-width: 760px) {
		.post-item {
			padding: 1.4rem;
		}

		.post-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}
</style>

<script>
	const searchInput = document.querySelector('#post-search');
	const searchEmpty = document.querySelector('#search-empty');
	const cards = Array.from(document.querySelectorAll('[data-post-card]'));

	if (searchInput && searchEmpty) {
		searchInput.addEventListener('input', (event) => {
			const query = event.currentTarget.value.trim().toLowerCase();
			let visibleCount = 0;

			for (const card of cards) {
				const haystack = card.dataset.search || '';
				const matched = !query || haystack.includes(query);
				card.hidden = !matched;
				if (matched) visibleCount += 1;
			}

			searchEmpty.hidden = visibleCount !== 0;
		});
	}
</script>
